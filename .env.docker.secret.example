# WeatherWear — Docker Compose Environment Variables (example)
# Copy to .env.docker.secret and fill in real values

# Telegram Bot — get token from @BotFather on Telegram
BOT_TOKEN=<your-bot-token>

# LLM (Qwen) — your LLM API endpoint and key
LLM_API_BASE_URL=<your-llm-base-url>
LLM_API_KEY=<your-api-key>
LLM_API_MODEL=qwen3-coder-plus

# Secondary LLM for fallback (optional, same endpoint is fine)
LLM_API_BASE_URL_2=<your-llm-base-url>
LLM_API_MODEL_2=coder-model
