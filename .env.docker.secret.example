# WeatherWear — Docker Compose Environment Variables (example)
# Copy to .env.docker.secret and fill in real values

# Telegram Bot — get from @BotFather
BOT_TOKEN=<your-bot-token>

# LLM (Qwen) — API endpoint for the LLM service
LLM_API_BASE_URL=http://<llm-vm-ip>:42005/v1
LLM_API_KEY=<your-qwen-api-key>
LLM_API_MODEL=qwen3-coder-plus
